<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Welcome!{% endblock %}</title>

    {% block stylesheets %}
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" integrity="sha512-2SwdPD6INVrV/lHTZbO2nodKhrnDdJK9/kg2XD1r9uGqPo1cUbujc+IYdlYdEErWNu69gVcYgdxlmVmzTWnetw==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    {% endblock %}
    {% block javascripts %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}
</head>
<body>
<i class="fa-solid fa-house"></i>
<i class="fas fa-house"></i>
{% block nav %}
    <nav>
        <ul>
            <li><strong>
                    <i class="fa-solid fa-house"></i>
                    MMIPLE</strong></li>
        </ul>
        <ul>
            <li><a href="{{ path('app_accueil') }}">{{ 'Accueil'|trans }}</a></li>
            <li><a href="{{ path('app_jeux') }}">{{ 'Jeux'|trans }}</a></li>
            <li><a href="{{ path('app_editeur_index') }}">{{ 'Editeurs'|trans }}</a></li>
            <li><a href="{{ path('contact') }}">{{ 'Contact'|trans }}</a></li>
            <li><a href="{{ path('app_apropos') }}">{{ 'A Propos'|trans }}</a></li>
            <li>
                <a href="{{ path('app_panier') }}">
                    <i class="fa-solid fa-cart-shopping"></i>
                {{ 'Panier'|trans }}
                </a>
            </li>
            <li>
                <a href="{{ path('app_jeux', {_locale: 'fr'}) }}">Version française</a>
            </li>
            <li>
                <a href="{{ path('app_jeux', {_locale: 'en'}) }}">English version</a>
            </li>
        </ul>
    </nav>
{% endblock %}

{% block main %}
{% endblock %}

{%  block footer %}
    <footer style="position: absolute; bottom: 0;">@Designed By MMI</footer>
{% endblock %}
</body>
</html>
